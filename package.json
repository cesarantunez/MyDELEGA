    "postinstall": "node -e \"const fs=require('fs');const d='node_modules/sql.js/dist';const o='public/wasm';if(fs.existsSync(d)){fs.mkdirSync(o,{recursive:true});['sql-wasm.wasm','sql-wasm-browser.wasm'].forEach(f=>{if(fs.existsSync(d+'/'+f)){fs.copyFileSync(d+'/'+f,o+'/'+f);console.log(f+' copied')}})}\""
